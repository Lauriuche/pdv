# ===================================
# ARQUIVO DE EXEMPLO - VARIÁVEIS DE AMBIENTE
# ===================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para: .env
# 2. Preencha com suas credenciais reais
# 3. NUNCA faça commit do arquivo .env (já está no .gitignore)
#
# ===================================

# Porta do servidor proxy
PORT=3000

# Token MercadoPago (Produção)
# Obtenha em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN_PROD=

# Token MercadoPago (Teste)
MP_ACCESS_TOKEN_TEST=

# Modo de desenvolvimento
NODE_ENV=development
